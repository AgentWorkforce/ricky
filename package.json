{
  "name": "@agentworkforce/ricky",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "description": "Workflow reliability, coordination, and authoring product for AgentWorkforce",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentWorkforce/ricky.git"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "bin": {
    "ricky": "./dist/ricky.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "npm --workspace @ricky/cli run start --",
    "clean": "npm run clean --workspaces --if-present && node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "tsc -b tsconfig.build.json",
    "bundle": "node scripts/bundle-cli.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:flat-layout": "RICKY_INCLUDE_FLAT_LAYOUT_PROOF=1 vitest run test/flat-layout-proof/flat-layout-proof.test.ts",
    "test:workspaces": "npm test --workspaces --if-present",
    "batch": "bash scripts/run-ricky-batch.sh",
    "overnight": "bash scripts/run-ricky-overnight.sh",
    "prepack": "npm run build && npm run bundle"
  },
  "dependencies": {
    "@agent-assistant/turn-context": "^0.3.11",
    "@agent-relay/sdk": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
