{
  "name": "ricky",
  "private": true,
  "version": "0.0.0",
  "license": "UNLICENSED",
  "description": "Workflow reliability, coordination, and authoring product for AgentWorkforce",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "packages/runtime",
    "packages/product",
    "packages/cloud",
    "packages/local",
    "packages/cli"
  ],
  "type": "module",
  "scripts": {
    "start": "npm run start --workspace @ricky/cli --",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit",
    "test": "npm run test --workspaces --if-present && vitest run test/package-proof/package-layout-proof.test.ts test/smoke.test.ts",
    "batch": "bash scripts/run-ricky-batch.sh",
    "overnight": "bash scripts/run-ricky-overnight.sh"
  },
  "dependencies": {
    "@agent-relay/sdk": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
