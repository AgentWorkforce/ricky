{
  "name": "@ricky/product",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "development": "./src/*.ts",
      "import": "./dist/*.js"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root ../.. packages/product/src"
  },
  "dependencies": {
    "@ricky/shared": "0.1.1",
    "@ricky/runtime": "0.1.1"
  }
}
